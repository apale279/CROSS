# Opzionale: se assente, usa l'unico doc in `manifestazioni` oppure il primo se ce ne sono più di uno.
# Impostalo solo per forzare un ID specifico.
# Stesso valore che prima era nel path /manifestazione/<questo-id>/…
VITE_TENANT_ID=
VITE_GOOGLE_MAPS_API_KEY=
VITE_SUPERADMIN=false

# Firebase (client)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Telegram — solo UI (link al bot); token e webhook solo su Vercel (server)
VITE_TELEGRAM_BOT_USERNAME=

# Sviluppo locale: proxy Vite inoltra /api verso questo host (NON usare URL assoluti nel browser)
VITE_API_BASE_URL=https://tuo-progetto.vercel.app
# Dopo il deploy: node scripts/register-telegram-webhook.mjs (vedi script per variabili)

# Piantina + guida PDF — Cloudinary (consigliato senza Firebase Storage)
# Preset "unsigned": abilita immagini (piantina) e Raw/PDF (guida); cartelle cross/piantine e cross/guida
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# --- Variabili SERVER (Vercel → Environment Variables, NON prefisso VITE_) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_TENANT_ID=          # stesso ID tenant di VITE_TENANT_ID
# TELEGRAM_WEBHOOK_SECRET=     # opzionale, consigliato (secret_token del webhook)
# FIREBASE_SERVICE_ACCOUNT_JSON=  # JSON service account Firebase (una riga)
# Upload lato server (piantina API, guida PDF CLI) — stesse chiavi su Vercel:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
#
# Rigenera GUIDA.pdf da GUIDA.md:  npm run generate:guida-pdf
# Carica guida PDF in Firestore (da root: GUIDA.pdf):
#   node --env-file=.env.local scripts/upload-guida-pdf.mjs
#   npm run upload:guida-pdf
