# Opzionale: se in Firestore c'è un solo doc in `manifestazioni`, viene rilevato automaticamente.
# Obbligatorio se ci sono più documenti (scegli l'ID da usare).
# Stesso valore che prima era nel path /manifestazione/<questo-id>/…
VITE_TENANT_ID=
VITE_GOOGLE_MAPS_API_KEY=
VITE_SUPERADMIN=false

# Firebase (client)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Telegram — solo UI (link al bot); token e webhook solo su Vercel (server)
VITE_TELEGRAM_BOT_USERNAME=

# Sviluppo locale (npm run dev): proxy /api verso il deploy Vercel (dominio produzione del progetto)
# VITE_API_BASE_URL=https://tuo-progetto.vercel.app
# Dopo il deploy: node scripts/register-telegram-webhook.mjs (vedi script per variabili)

# Piantina tabellone tattico — Cloudinary (consigliato senza Firebase Storage)
# Crea un Upload preset "unsigned" con cartella cross/piantine
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# --- Variabili SERVER (Vercel → Environment Variables, NON prefisso VITE_) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_TENANT_ID=          # stesso ID tenant di VITE_TENANT_ID
# TELEGRAM_WEBHOOK_SECRET=     # opzionale, consigliato (secret_token del webhook)
# FIREBASE_SERVICE_ACCOUNT_JSON=  # JSON service account Firebase (una riga)
# Alternativa upload piantina lato server (se non usi il preset unsigned nel client):
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
