# Opzionale: se in Firestore c'Ă¨ un solo doc in `manifestazioni`, viene rilevato automaticamente.
# Obbligatorio se ci sono piĂą documenti (scegli l'ID da usare).
# Stesso valore che prima era nel path /manifestazione/<questo-id>/â€¦
VITE_TENANT_ID=
VITE_GOOGLE_MAPS_API_KEY=
VITE_SUPERADMIN=false

# Firebase (client)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Telegram â€” solo UI (link al bot); token e webhook solo su Vercel (server)
VITE_TELEGRAM_BOT_USERNAME=

# --- Variabili SERVER (Vercel â†’ Environment Variables, NON prefisso VITE_) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_TENANT_ID=          # stesso ID tenant di VITE_TENANT_ID
# TELEGRAM_WEBHOOK_SECRET=     # opzionale, consigliato (secret_token del webhook)
# FIREBASE_SERVICE_ACCOUNT_JSON=  # JSON service account Firebase (una riga)
