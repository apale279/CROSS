# Copia queste variabili su Vercel (progetto SANDBOX o ambiente Preview).
# NON sostituire le variabili del deploy di produzione.

# Obbligatorio: ID del tenant creato con npm run sandbox:create (vedi sandbox/TENANT_ID)
VITE_TENANT_ID=

# Barra SANDBOX + blocco scritture sul tenant produzione
VITE_APP_SANDBOX=true
# ID tenant produzione (es. Lr4XjZMr4UWWJWD2m0iW) — abilita badge + blocco scritture su prod
VITE_PRODUCTION_TENANT_ID=

# Stesse del progetto Firebase prod
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=

# Mappe + upload asset (piantina, guida, foto PMA)
VITE_GOOGLE_MAPS_API_KEY=
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Opzionale
VITE_SUPERADMIN=true

# NON impostare VITE_API_BASE_URL verso il deploy di produzione

# NON impostare su sandbox (Telegram non usato):
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_TENANT_ID=
# TELEGRAM_WEBHOOK_SECRET=
# VITE_TELEGRAM_BOT_USERNAME=
